{
  "name": "openclaw-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.16",
  "scripts": {
    "dev": "bunx --bun next dev",
    "build": "NODE_ENV=production bunx --bun next build",
    "start": "bunx --bun next start",
    "check": "bunx tsc --noEmit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "openclaw:check": "bash scripts/check-openclaw.sh",
    "test": "bun test",
    "dispatcher": "bun src/server/dispatcher-worker.ts",
    "skill-installer": "bun src/server/skill-installer-worker.ts"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.0",
    "@tanstack/react-query": "^5.80.7",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.9.2",
    "image-size": "1.1.1",
    "lucide-react": "^0.542.0",
    "next": "^15.5.2",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@tailwindcss/postcss": "^4.1.13",
    "drizzle-kit": "^0.31.4",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2"
  }
}
